# ===== Proveedor de IA =====
# "openai" (o endpoint compatible) | "ollama" (local, gratis)
LLM_PROVIDER=openai

# Opcional: usar un proveedor distinto para chat y para embeddings.
# Si se omiten, ambos usan LLM_PROVIDER.
# Ejemplo: chat por API remota + embeddings locales:
#   CHAT_PROVIDER=openai
#   EMBEDDINGS_PROVIDER=ollama

# ===== OpenAI (o endpoint compatible) =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL: vacío = OpenAI oficial. Para endpoints compatibles:
#   Groq (solo chat, gratis):  https://api.groq.com/openai/v1
#   Gemini (chat + embeddings, gratis): https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_BASE_URL=

# ===== Ollama (local) =====
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ===== RAG =====
TOP_K=4
SCORE_THRESHOLD=0.35
QDRANT_PATH=./qdrant_data
# QDRANT_URL: si se define, usa Qdrant como servidor (Docker). Dejar vacío para modo local.
QDRANT_URL=
QDRANT_COLLECTION=minecatalog

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
REQUEST_TIMEOUT=60
